# ─────────────────────────────────────────────
# Resend — Email delivery
# Get your API key at https://resend.com
# ─────────────────────────────────────────────

RESEND_API_KEY=re_your_api_key_here

# The email address emails are sent FROM.
# On the free Resend plan (no custom domain) use:  onboarding@resend.dev
# With a verified domain use:  Kraftify Bookings <bookings@yourdomain.com>
RESEND_FROM_EMAIL=Kraftify Bookings <bookings@yourdomain.com>
